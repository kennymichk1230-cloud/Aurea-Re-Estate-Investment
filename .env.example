# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FLUTTERWAVE_PUBLIC_KEY: Required for Flutterwave card payment gateway deposits.
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-YOUR_PUBLIC_KEY_HERE-X

# FLUTTERWAVE_SECRET_KEY: Required for Flutterwave withdrawal bank transfers and charge processing.
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-YOUR_SECRET_KEY_HERE-X

